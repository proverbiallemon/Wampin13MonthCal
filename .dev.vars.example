# Copy this file to .dev.vars and fill in your values
# This file is used by Wrangler for local development

# Google OAuth credentials
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# Optional: Override the OAuth redirect URI for local development.
# Uncomment and set this if you get a "redirect_uri_mismatch" error.
# The value must exactly match one of the authorized redirect URIs
# configured in your Google Cloud Console OAuth credentials.
# GOOGLE_REDIRECT_URI=http://localhost:8788/api/auth/google